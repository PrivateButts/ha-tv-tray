#!/usr/bin/env python3
"""Bump version in pyproject.toml on explicit `git commit -m`.

Only acts during `git commit -m "msg"`.  Silent.  Skips during
rebase, merge, interactive commit, and amend.
"""

import re
import subprocess
import sys
from pathlib import Path

REPO = Path(__file__).resolve().parent.parent
PYPROJECT = REPO / "pyproject.toml"


def _bump_type(msg: str) -> str:
    if re.search(r"^(.*!|BREAKING CHANGE)", msg):
        return "major"
    if re.match(r"^feat(\(.+\))?:", msg):
        return "minor"
    return "patch"


def _bump(ver: str, kind: str) -> str:
    parts = [int(p) for p in ver.split(".")]
    while len(parts) < 3:
        parts.append(0)
    m, n, p = parts[:3]
    if kind == "major":
        return f"{m + 1}.0.0"
    if kind == "minor":
        return f"{m}.{n + 1}.0"
    return f"{m}.{n}.{p + 1}"


def main():
    if not PYPROJECT.exists():
        return

    source = sys.argv[2] if len(sys.argv) > 2 else ""

    # Only act on explicit `git commit -m "..."` — skip rebase,
    # merge, interactive, amend, etc.
    if source != "message":
        return

    msg = Path(sys.argv[1]).read_text().strip().split("\n")[0]
    kind = _bump_type(msg)

    text = PYPROJECT.read_text()
    m = re.search(r'^version\s*=\s*"([^"]+)"', text, re.MULTILINE)
    if not m:
        return

    old = m.group(1)
    new = _bump(old, kind)

    text = text.replace(f'version = "{old}"', f'version = "{new}"', 1)
    PYPROJECT.write_text(text)
    subprocess.run(["git", "add", "pyproject.toml"], check=True)


if __name__ == "__main__":
    main()
